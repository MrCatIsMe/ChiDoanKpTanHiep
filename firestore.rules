rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write for youth members
    match /doanVien/{id} {
      allow read, write: if true;
    }

    // Allow read/write for summer activities
    match /hoatDong/{id} {
      allow read, write: if true;
    }

    // Allow read/write for evidence submissions
    match /minhChung/{id} {
      allow read, write: if true;
    }

    // Allow read/write for user accounts
    match /users/{id} {
      allow read, write: if true;
    }

    // Allow read/write for schools list
    match /truongHoc/{id} {
      allow read, write: if true;
    }

    // Allow read/write for application settings
    match /settings/{id} {
      allow read, write: if true;
    }
  }
}
